generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Show {
  id          String   @id @default(cuid())
  title       String
  description String
  genre       String
  year        Int
  imageUrl    String
  createdAt   DateTime @default(now())
  createdBy   String
  reviews     Review[]
}

model Review {
  id        String   @id @default(cuid())
  title     String?
  author    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  showId    String
  show      Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
}
