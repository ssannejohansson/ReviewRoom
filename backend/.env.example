PORT=3001
CORS_ORIGIN=http://localhost:5500

# Firebase credentials (add your actual credentials from Firebase Console)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# TMDB API key (only needed to run backend/scripts/update-posters.mjs)
TMDB_API_KEY=your_tmdb_api_key

# Database connection string (update with your actual database credentials)
DATABASE_URL="DATABASE_URL="postgresql://your-username@localhost:5432/your-db-name"